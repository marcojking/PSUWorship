{
  "name": "wma-live",
  "version": "1.0.0",
  "description": "WMA Live — offline-capable worship lyrics control",
  "main": "dist/main.cjs",
  "type": "commonjs",
  "scripts": {
    "bundle": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dev": "node build.mjs && electron .",
    "dist": "node build.mjs && electron-builder"
  },
  "build": {
    "appId": "org.wmaac.live",
    "productName": "WMA Live",
    "files": ["dist/**/*", "renderer/**/*", "package.json"],
    "win": { "target": "nsis" }
  },
  "dependencies": {
    "convex": "^1.13.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0"
  }
}
